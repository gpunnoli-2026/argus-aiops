# Copy to .env and fill in. NEVER commit .env.
# Slack (Socket Mode — no public endpoint needed)
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...
SLACK_SIGNING_SECRET=...
SLACK_CHANNEL_INCIDENTS=#argus-incidents

# MLflow
MLFLOW_TRACKING_URI=http://mlflow.mlflow:5000
ARTIFACT_ENDPOINT=            # empty = AWS S3; set for MinIO on kind
ARTIFACT_BUCKET=argus-artifacts

# AWS (local tooling only; in-cluster access uses IRSA)
AWS_REGION=us-west-2
AWS_PROFILE=argus
